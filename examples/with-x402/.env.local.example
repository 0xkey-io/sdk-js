# 0xkey Pay Playground with local Company Wallet signing.
# For staging wallet/signing, copy .env.staging.example to .env.staging.local,
# fill secrets there, then copy it to .env.local for that run.
NEXT_PUBLIC_FACILITATOR_URL=http://localhost:8090

# Base Sepolia test USDC settlement.
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
NEXT_PUBLIC_RESOURCE_WALLET_ADDRESS=0xfB65e93108ac2bA9a5e7A997F8080b40eA551104

# Organization used by the Pay Orchestrator for /settle and payment records.
# Defaults to ZEROXKEY_ORGANIZATION_ID if omitted.
PAY_ORGANIZATION_ID=your-pay-organization-id

# Optional if the Orchestrator requires bearer auth.
FACILITATOR_API_KEY=your-pay-facilitator-api-key

# Company Wallet mode (recommended and shown in the page).
# Use a local test organization / wallet account only. Never commit real keys.
ZEROXKEY_API_PUBLIC_KEY=your-api-public-key
ZEROXKEY_API_PRIVATE_KEY=your-api-private-key
ZEROXKEY_ORGANIZATION_ID=your-organization-id

# Can be a wallet account address or privateKeyId.
ZEROXKEY_SIGN_WITH=your-wallet-account-address-or-private-key-id

# Required when ZEROXKEY_SIGN_WITH is a privateKeyId.
ZEROXKEY_ETHEREUM_ADDRESS=0xYourCompanyWalletEthereumAddress

# Local Public API Gateway used for Company Wallet signing.
ZEROXKEY_API_BASE_URL=http://localhost:8080

# Hidden local-key smoke fallback for API/CLI debugging only.
# The page does not expose this mode.
# BUYER_PRIVATE_KEY=0xYourBaseSepoliaBuyerPrivateKey
# X402_RS_EVM_PRIVATE_KEY=0xYourBaseSepoliaFacilitatorSignerPrivateKey
