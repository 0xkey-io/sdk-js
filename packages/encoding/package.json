      "default": "./dist/index.mjs"
    }
  },
  "types": "./dist/index.d.ts",
  "license": "Apache-2.0",
  "description": "Encoding utility functions",
  "author": {
    "name": "0xkey",
    "url": "https://0xkey.com/"
  },
