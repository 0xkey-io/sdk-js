# If you want to run unit tests, populate these values and save this file as a new `.env` file
API_PUBLIC_KEY="<ZeroXKey API Public Key (that starts with 02 or 03)>"
API_PRIVATE_KEY="<ZeroXKey API Private Key>"
BASE_URL="https://api.0xkey.com"
ORGANIZATION_ID="<ZeroXKey organization ID>"
EXPECTED_WALLET_ACCOUNT_ETH_ADDRESS="<A wallet account>"
WALLET_ID="<The wallet ID containing the wallet account above>"
