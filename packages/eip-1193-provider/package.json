    "EIP-1193",
    "Ethereum",
    "Ethereum Provider"
  ],
  "author": {
    "name": "0xkey",
    "url": "https://0xkey.com/"
  },
  "homepage": "https://github.com/0xkey-io/sdk-js/tree/main/packages/eip-1193-provider",
  "bugs": {
    "url": "https://github.com/0xkey-io/sdk-js/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0xkey-io/sdk-js.git",
    "directory": "packages/eip-1193-provider"
  },
  "files": [
    "dist/",
    "CHANGELOG.md",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "viem": "2.7.19",
    "@0xkey-io/api-key-stamper": "workspace:*",
    "@0xkey-io/http": "workspace:*",
    "@0xkey-io/sdk-browser": "workspace:*",
    "@0xkey-io/core": "workspace:*"
  },
  "devDependencies": {
    "hardhat": "^2.22.2",
    "typescript": "5.4.3"
  }
}
