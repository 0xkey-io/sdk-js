API_PRIVATE_KEY="<ZeroXKey API Private Key>"
BASE_URL="https://api.0xkey.com"
ORGANIZATION_ID="<ZeroXKey organization ID>"
PRIVATE_KEY_ID="<ZeroXKey (crypto) private key ID>"
EXPECTED_PRIVATE_KEY_ETH_ADDRESS="<Corresponding to the private key above>"
EXPECTED_WALLET_ACCOUNT_ETH_ADDRESS="<0x...>"
BANNED_TO_ADDRESS="<0x...>"
