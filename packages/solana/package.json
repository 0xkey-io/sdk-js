{
  "name": "@0xkey-io/solana",
  "version": "0.1.1",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.mjs"
    }
  },
  "types": "./dist/index.d.ts",
  "license": "Apache-2.0",
  "description": "0xkey Solana Signer for @solana/web3js",
  "keywords": [
    "0xkey",
    "Solana",
    "web3js",
    "web3"
  ],
  "author": {
    "name": "0xkey",
    "url": "https://0xkey.com/"
  },
  "homepage": "https://github.com/0xkey-io/sdk-js/tree/main/packages/solana",
  "bugs": {
    "url": "https://github.com/0xkey-io/sdk-js/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0xkey-io/sdk-js.git",
    "directory": "packages/solana"
  },
  "files": [
    "dist/",
    "CHANGELOG.md",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepublishOnly": "pnpm run clean && pnpm run build",
    "build": "rollup -c",
    "clean": "rimraf ./dist ./.cache",
    "test": "DOTENV_CONFIG_PATH=.env.test jest --passWithNoTests",
    "typecheck": "tsc -p tsconfig.typecheck.json"
  },
  "dependencies": {
    "@solana/web3.js": "^1.95.8",
    "@0xkey-io/http": "workspace:*",
    "@0xkey-io/sdk-browser": "workspace:*",
    "@0xkey-io/sdk-server": "workspace:*",
    "@0xkey-io/core": "workspace:*"
  },
  "devDependencies": {
    "@0xkey-io/api-key-stamper": "workspace:*",
    "@0xkey-io/encoding": "workspace:*",
    "tweetnacl": "^1.0.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
